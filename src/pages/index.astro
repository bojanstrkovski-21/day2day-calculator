---
import Holidays from 'date-holidays';

// These optional holidays are officially non-working for all MK citizens
const EXTRA_NON_WORKING = new Set([
  'Велики Петок',                      // Orthodox Good Friday (date varies by year)
  'Успение на Пресвета Богородица',    // Dormition of the Theotokos — Aug 28 (fixed)
  'Бадник',                            // Orthodox Christmas Eve — Jan 6 (fixed)
  'Богојавление',                      // Epiphany / Vodici — Jan 19 (fixed)
  'петок пред Духовден',               // Whit Friday / Friday before Pentecost (date varies)
]);

// Pre-generate MK holidays for current year ±2 years at build time
const hd = new Holidays('MK');
const currentYear = new Date().getFullYear();
const holidayMap: Record<string, string> = {};
for (let y = currentYear - 2; y <= currentYear + 5; y++) {
  const list = hd.getHolidays(y);
  for (const h of list) {
    if (h.type === 'public' || EXTRA_NON_WORKING.has(h.name)) {
      holidayMap[h.date.slice(0, 10)] = h.name;
    }
  }
}
// Remove Sunday holidays — the package already adds the Monday substitute (заменет ден)
for (const dateStr of Object.keys(holidayMap)) {
  const d = new Date(dateStr + 'T00:00:00');
  if (d.getDay() === 0) delete holidayMap[dateStr];
}
const holidaysJSON = JSON.stringify(holidayMap);
